@using PasswordGenerator.Domain.Enums

<div class="strength-indicator">
    <div class="strength-bar">
        <div class="strength-fill @StrengthClass" style="width: @StrengthPercent%"></div>
    </div>
    <div class="strength-label">
        <span class="@StrengthClass">@StrengthText</span>
        <span class="entropy-value">@Entropy.ToString("F1") bits</span>
    </div>
</div>

@code {
    [Parameter] public PasswordStrength Strength { get; set; }
    [Parameter] public double Entropy { get; set; }

    private string StrengthText => Strength switch
    {
        PasswordStrength.VeryWeak => "Very Weak",
        PasswordStrength.Weak => "Weak",
        PasswordStrength.Fair => "Fair",
        PasswordStrength.Strong => "Strong",
        PasswordStrength.VeryStrong => "Very Strong",
        _ => ""
    };

    private string StrengthClass => Strength switch
    {
        PasswordStrength.VeryWeak => "very-weak",
        PasswordStrength.Weak => "weak",
        PasswordStrength.Fair => "fair",
        PasswordStrength.Strong => "strong",
        PasswordStrength.VeryStrong => "very-strong",
        _ => ""
    };

    private int StrengthPercent => Strength switch
    {
        PasswordStrength.VeryWeak => 10,
        PasswordStrength.Weak => 30,
        PasswordStrength.Fair => 55,
        PasswordStrength.Strong => 80,
        PasswordStrength.VeryStrong => 100,
        _ => 0
    };
}
